        {
            "finding": "Branch skipping is counterproductive",
            "evidence": "v1 is 9.43% SLOWER than dense baseline",
            "implication": "Warp divergence from in-kernel branching costs more than the computation it avoids. This explains why naive sparse kernels fail on GPUs."
        },
        {
            "finding": "Row packing achieves 69.83% hardware speedup",
            "evidence": "v2 runs in 0.5691ms vs 0.9665ms dense",
            "implication": "Pre-packing active elements eliminates divergence. The GPU sees a fully dense operation on 27.12% of data. This is 95.8% of the theoretical maximum speedup."
        },
